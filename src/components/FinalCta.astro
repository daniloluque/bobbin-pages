<section class="final-cta" data-theme="dark">
  <div class="container final-cta-inner">
    <div class="cta-badge">
      <span class="rec-dot"></span>
      <span class="badge-label">Comece hoje</span>
    </div>
    <h2 class="cta-heading">
      Seu próximo anúncio vencedor<br />está a um clique de distância
    </h2>
    <p class="cta-sub">Sem cartão de crédito. Seus primeiros 5 vídeos são gratuitos.</p>
    <a href="#" class="btn btn-primary btn-xl">Começar gratuitamente</a>
  </div>
</section>

<style>
  .final-cta {
    padding: 120px 0;
    background-color: var(--color-bg);
  }

  .final-cta-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .cta-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(255, 45, 45, 0.10);
    border: 1px solid rgba(255, 45, 45, 0.28);
    border-radius: var(--radius-full);
    padding: 6px 16px;
    margin-bottom: 36px;
  }

  .badge-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-mono-sm);
    text-transform: uppercase;
    color: var(--color-rec-500);
  }

  .cta-heading {
    font-family: var(--font-display);
    font-weight: var(--font-weight-bold);
    font-size: clamp(36px, 5vw, 60px);
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight-2);
    color: var(--color-text);
    margin: 32px 0 16px;
  }

  .cta-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: 40px;
  }
</style>
